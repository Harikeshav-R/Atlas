{
  "name": "@atlas/desktop",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "build": {
    "appId": "com.atlas.app",
    "productName": "Atlas",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "extraResources": [
      {
        "from": "../../packages/db/migrations",
        "to": "migrations",
        "filter": ["**/*"]
      }
    ],
    "files": [
      "out/**/*",
      "package.json"
    ]
  },
  "dependencies": {
    "@atlas/agents": "workspace:*",
    "@atlas/db": "workspace:*",
    "@atlas/harness": "workspace:*",
    "@atlas/mcp-atlas-cost": "workspace:*",
    "@atlas/mcp-atlas-db": "workspace:*",
    "@atlas/mcp-atlas-fs": "workspace:*",
    "@atlas/mcp-atlas-profile": "workspace:*",
    "@atlas/mcp-atlas-stories": "workspace:*",
    "@atlas/mcp-atlas-user": "workspace:*",
    "@atlas/mcp-atlas-web": "workspace:*",
    "@atlas/model-router": "workspace:*",
    "@atlas/schemas": "workspace:*",
    "@atlas/shared": "workspace:*",
    "@playwright/mcp": "^0.0.70",
    "@tanstack/react-query": "^5.97.0",
    "@tanstack/react-router": "^1.168.10",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "keytar": "^7.9.0",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
