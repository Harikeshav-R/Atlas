{
  "name": "atlas",
  "version": "0.0.0",
  "private": true,
  "description": "Local-first, agentic job application desktop app.",
  "license": "AGPL-3.0-or-later",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "test:integration": "turbo run test:integration",
    "test:e2e": "turbo run test:e2e",
    "eval": "turbo run eval --filter=@atlas/eval",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,yml,yaml}\"",
    "typecheck": "turbo run typecheck",
    "db:migrate": "pnpm --filter @atlas/db db:migrate",
    "db:generate": "pnpm --filter @atlas/db db:generate",
    "changeset": "changeset"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/node": "^25.5.2",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "turbo": "^2.9.5",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1"
  }
}
